# ══════════════════════════════════════════════════════
#   Autonomous AI Engineer — Configuration
#   Copy this file to config/.env and fill in values
# ══════════════════════════════════════════════════════

# ── LLM Provider ────────────────────────────────────
# Option A: OpenAI (paid, best quality)
OPENAI_API_KEY=sk-your-key-here

# Option B: Anthropic Claude (alternative)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option C: Groq (FREE tier available! Fast inference)
# Get free key at: https://console.groq.com
# GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=llama-3.1-70b-versatile

# Option D: Google Gemini (FREE tier available!)
# Get free key at: https://aistudio.google.com
# GEMINI_API_KEY=your-key-here

# ── Active LLM Config ───────────────────────────────
LLM_PROVIDER=groq          # openai | anthropic | groq | gemini | ollama
LLM_MODEL=llama-3.1-70b-versatile
LLM_MINI_MODEL=llama-3.1-8b-instant   # cheaper model for retry iterations

# ── GitHub ──────────────────────────────────────────
# Personal Access Token (free, from github.com/settings/tokens)
# Scopes needed: repo, read:org
GITHUB_TOKEN=ghp_your-token-here
GITHUB_USERNAME=your-github-username

# ── Sandbox ─────────────────────────────────────────
SANDBOX_MEMORY_MB=512
SANDBOX_CPU_QUOTA=0.5
SANDBOX_TIMEOUT_SECONDS=30

# ── Agent Settings ───────────────────────────────────
MAX_RETRY_ITERATIONS=8
MIN_MEMORY_SIMILARITY=0.82
DIVERGENCE_THRESHOLD=0.95
TARGET_CRITIC_APPROVAL_RATE=0.85
MAX_COST_PER_TASK_USD=3.0

# ── Paths ────────────────────────────────────────────
FAISS_INDEX_PATH=./data/faiss_index
MEMORY_STORE_PATH=./data/memory_store
LOGS_PATH=./data/logs
